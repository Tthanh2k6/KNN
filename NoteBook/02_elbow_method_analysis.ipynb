# Code trực quan

import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from wcss_function import tinh_wcss   # import hàm từ file bên cạnh

# ── BƯỚC 1: Load dữ liệu sạch từ TV4 ────────────────────

iris_df = pd.read_csv('scaled_iris.csv')
mall_df = pd.read_csv('scaled_Mall_Customer.csv')

X_iris = iris_df[['sepal_length', 'sepal_width',
                   'petal_length', 'petal_width']].values

X_mall = mall_df[['Age', 'Annual_Income',
                   'Spending_Score']].values

# ── BƯỚC 2: Gọi hàm tính WCSS ────────────────────────────

wcss_iris = tinh_wcss(X_iris, "Iris")
wcss_mall = tinh_wcss(X_mall, "Mall Customers")

# ── BƯỚC 3: Vẽ Elbow Chart ───────────────────────────────

fig, axes = plt.subplots(1, 2, figsize=(14, 5))
fig.suptitle('Elbow Method — WCSS (K=1→10) | Dữ liệu sạch TV4',
             fontsize=14, fontweight='bold')

datasets = [
    (wcss_iris, 'Iris',           3, '#3266ad'),
    (wcss_mall, 'Mall Customers', 5, '#1d9e75'),
]

for ax, (wcss, title, elbow_k, color) in zip(axes, datasets):

    # Đường WCSS
    ax.plot(range(1, 11), wcss,
            marker='o', linewidth=2.5, color=color,
            markerfacecolor='white', markeredgewidth=2, markersize=9)

    # Highlight điểm Elbow
    ax.scatter([elbow_k], [wcss[elbow_k - 1]],
               s=180, color='#d85a30', zorder=5,
               edgecolors='white', linewidths=2)
    ax.annotate(f'Elbow  K={elbow_k}',
                xy=(elbow_k, wcss[elbow_k - 1]),
                xytext=(elbow_k + 0.8, wcss[elbow_k - 1] + 15),
                arrowprops=dict(arrowstyle='->', color='#d85a30', lw=1.8),
                fontsize=11, color='#d85a30', fontweight='bold')
    ax.axvline(x=elbow_k, color='#d85a30',
               linestyle='--', linewidth=1.5, alpha=0.5)

    # Gán giá trị lên mỗi điểm
    for k, w in zip(range(1, 11), wcss):
        ax.annotate(f'{w:.1f}', xy=(k, w), xytext=(0, 10),
                    textcoords='offset points',
                    ha='center', fontsize=7.5)

    ax.set_title(title, fontsize=13)
    ax.set_xlabel('Số cụm K')
    ax.set_ylabel('WCSS (Inertia)')
    ax.set_xticks(range(1, 11))
    ax.grid(True, linestyle='--', alpha=0.4)

plt.tight_layout()
plt.savefig('elbow_tv5.png', dpi=150, bbox_inches='tight')
plt.show()
print("\nĐã lưu: elbow_tv5.png")
