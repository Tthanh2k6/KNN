   "source": [
    "# ===== ELBOW METHOD =====\n",
    "wcss = []\n",
    "K_range = range(1, 11)\n",
    "\n",
    "for k in K_range:\n",
    "    kmeans = KMeans(n_clusters=k, random_state=42)\n",
    "    kmeans.fit(X)\n",
    "    wcss.append(kmeans.inertia_)\n",
    "\n",
    "plt.figure(figsize=(12,8))\n",
    "\n",
    "# Elbow (chiếm 1 ô lớn)\n",
    "plt.subplot(3,2,1)\n",
    "plt.plot(K_range, wcss, marker='o')\n",
    "plt.title(\"Elbow Method\")\n",
    "plt.xlabel(\"K\")\n",
    "plt.ylabel(\"WCSS\")\n",
    "plt.grid(True)\n",
    "\n",
    "# ===== SUBPLOT =====\n",
    "K_values = [2, 3, 4, 5]\n",
    "\n",
    "for i, k in enumerate(K_values):\n",
    "    kmeans = KMeans(n_clusters=k, random_state=42)\n",
    "    y = kmeans.fit_predict(X)\n",
    "\n",
    "    plt.subplot(3,2,i+3)\n",
    "    plt.scatter(X[:,0], X[:,1], c=y)\n",
    "    plt.title(f\"K = {k}\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
