    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.cluster import KMeans"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "9eac149e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Đọc dữ liệu\n",
    "df = pd.read_csv('../data/Đã xử lí/scaled_iris.csv')\n",
    "\n",
    "# Bỏ cột chữ (species)\n",
    "X = df.drop(columns=['species']).values"
   ]
